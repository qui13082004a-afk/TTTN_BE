    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Lecturer/Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is success', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "}",
                  "if (json.user && json.user.id_giang_vien) {",
                  "    pm.collectionVariables.set('lecturerId', String(json.user.id_giang_vien));",
                  "}",
                  "if (json.user && json.user.id_sinh_vien) {",
                  "    pm.collectionVariables.set('studentId', String(json.user.id_sinh_vien));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{lecturerEmail}}\",\n  \"password\": \"{{lecturerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Dang nhap bang tai khoan giang vien hoac admin. Tu dong luu token vao bien collection."
          }
        },
        {
          "name": "Login Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
